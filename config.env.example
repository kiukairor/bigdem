# PULSE — Single Config File
# Copy to config.env and fill in your values
# NEVER commit config.env to git

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-sonnet-4-20250514

# ── New Relic ─────────────────────────────────────────────────────────────────
NEW_RELIC_LICENSE_KEY=<APM ingest license key from NR console>
NEW_RELIC_ACCOUNT_ID=<numeric account ID>
# Browser-specific keys — filled in after creating Browser apps in NR console
# NR console → Add data → Browser → create "pulse-shell" / "pulse-feed" apps
NEW_RELIC_BROWSER_LICENSE_KEY=<browser ingest key — starts with NRJS-, shown in Browser snippet>
NEW_RELIC_BROWSER_APP_ID_SHELL=<numeric applicationID from pulse-shell Browser snippet>
NEW_RELIC_BROWSER_APP_ID_FEED=<numeric applicationID from pulse-feed Browser snippet>
NEW_RELIC_BROWSER_TRUST_KEY=<trustKey value from Browser snippet — usually the parent account ID>

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=pulse
POSTGRES_PASSWORD=coucoufdp
POSTGRES_DB=pulse
POSTGRES_HOST=postgresql
POSTGRES_PORT=5432

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── App ───────────────────────────────────────────────────────────────────────
DEMO_CITY=London
DEMO_USER_ID=demo_user
DEMO_USER_NAME=Demo User

# ── Services (internal K8s DNS) ───────────────────────────────────────────────
EVENT_SVC_URL=http://event-svc:8080
AI_SVC_URL=http://ai-svc:8082
SESSION_SVC_URL=http://session-svc:8081

# ── Circuit Breaker ───────────────────────────────────────────────────────────
CB_FAILURE_THRESHOLD=5
CB_RECOVERY_TIMEOUT_SECONDS=60

# ── Frontend public URLs (baked into the Next.js image at CI build time) ──────
# These are not secrets — they are the public-facing URLs the browser uses.
# To change them: update build-args in .github/workflows/pulse-shell.yml and
# .github/workflows/pulse-feed.yml, then push to trigger a rebuild.
# Local dev defaults (used when running next dev locally, not in K8s):
NEXT_PUBLIC_FEED_MFE_URL=http://localhost:3001
NEXT_PUBLIC_PROFILE_MFE_URL=http://localhost:3002
NEXT_PUBLIC_EVENT_SVC_URL=http://localhost:8080
NEXT_PUBLIC_AI_SVC_URL=http://localhost:8082
NEXT_PUBLIC_SESSION_SVC_URL=http://localhost:8081
