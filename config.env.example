# PULSE — Single Config File
# Copy to config.env and fill in your values
# NEVER commit config.env to git

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-sonnet-4-20250514

# ── New Relic ─────────────────────────────────────────────────────────────────
NEW_RELIC_LICENSE_KEY=<Your nr key>>
NEW_RELIC_ACCOUNT_ID=<your nr account id>

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=pulse
POSTGRES_PASSWORD=coucoufdp
POSTGRES_DB=pulse
POSTGRES_HOST=postgresql
POSTGRES_PORT=5432

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── App ───────────────────────────────────────────────────────────────────────
DEMO_CITY=London
DEMO_USER_ID=demo_user
DEMO_USER_NAME=Demo User

# ── Services (internal K8s DNS) ───────────────────────────────────────────────
EVENT_SVC_URL=http://event-svc:8080
AI_SVC_URL=http://ai-svc:8082
SESSION_SVC_URL=http://session-svc:8081

# ── Circuit Breaker ───────────────────────────────────────────────────────────
CB_FAILURE_THRESHOLD=5
CB_RECOVERY_TIMEOUT_SECONDS=60

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_FEED_MFE_URL=http://pulse-feed:3001
NEXT_PUBLIC_PROFILE_MFE_URL=http://pulse-profile:3002
NEXT_PUBLIC_EVENT_SVC_URL=http://event-svc:8080
NEXT_PUBLIC_AI_SVC_URL=http://ai-svc:8082
NEXT_PUBLIC_SESSION_SVC_URL=http://session-svc:8081
