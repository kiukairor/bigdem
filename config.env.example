# PULSE — Single Config File
# Copy to config.env and fill in your values
# NEVER commit config.env to git

# ── Anthropic (optional — only needed when AI_PROVIDER=claude) ────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-sonnet-4-20250514

# ── Google Gemini (default AI provider) ───────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-3.1-flash-lite-preview

# ── Ticketmaster (event sync CronJob — London events) ─────────────────────────
TICKETMASTER_API_KEY=your-ticketmaster-api-key-here

# ── New Relic ─────────────────────────────────────────────────────────────────
# APM ingest key (40-char hex, eu01xx… prefix for EU region) — used by Go + Python agents
# Applied to K8s via: ./scripts/apply-secrets.sh pulse-prod
NEW_RELIC_LICENSE_KEY=<APM ingest license key — 40-char hex, eu01xx… for EU>
NEW_RELIC_ACCOUNT_ID=<numeric account ID>

# Browser keys for pulse-shell (runtime-injected via K8s secret → getServerSideProps)
# Source: NR console → Add data → Browser → copy snippet for pulse-shell app
# NRJS-… key is the same across all Browser apps in the same account
# Apply to cluster: ./scripts/apply-secrets.sh pulse-prod
NEW_RELIC_BROWSER_LICENSE_KEY=<NRJS-… key — same for all Browser apps in this account>
NEW_RELIC_BROWSER_TRUST_KEY=<trustKey from Browser snippet — usually equals account ID>
NEW_RELIC_BROWSER_APP_ID_SHELL=<applicationID from pulse-shell Browser snippet>

# pulse-feed and pulse-profile Browser credentials are baked into Docker images at CI build time
# (NEXT_PUBLIC_* vars cannot be injected at runtime in Next.js)
# Edit them directly in: .github/workflows/pulse-feed.yml and .github/workflows/pulse-profile.yml

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=pulse
POSTGRES_PASSWORD=coucoufdp
POSTGRES_DB=pulse
POSTGRES_HOST=postgresql
POSTGRES_PORT=5432

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── App ───────────────────────────────────────────────────────────────────────
DEMO_CITY=London
DEMO_USER_ID=demo_user
DEMO_USER_NAME=Demo User

# ── Services (internal K8s DNS) ───────────────────────────────────────────────
EVENT_SVC_URL=http://event-svc:8080
AI_SVC_URL=http://ai-svc:8082
SESSION_SVC_URL=http://session-svc:8081

# ── Circuit Breaker ───────────────────────────────────────────────────────────
CB_FAILURE_THRESHOLD=5
CB_RECOVERY_TIMEOUT_SECONDS=60

# ── Frontend public URLs (baked into the Next.js image at CI build time) ──────
# These are not secrets — they are the public-facing URLs the browser uses.
# To change them: update build-args in .github/workflows/pulse-shell.yml and
# .github/workflows/pulse-feed.yml, then push to trigger a rebuild.
# Local dev defaults (used when running next dev locally, not in K8s):
NEXT_PUBLIC_FEED_MFE_URL=http://localhost:3001
NEXT_PUBLIC_PROFILE_MFE_URL=http://localhost:3002
NEXT_PUBLIC_EVENT_SVC_URL=http://localhost:8080
NEXT_PUBLIC_AI_SVC_URL=http://localhost:8082
NEXT_PUBLIC_SESSION_SVC_URL=http://localhost:8081
